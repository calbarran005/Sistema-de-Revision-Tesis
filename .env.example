# ─── BASE DE DATOS (XAMPP MySQL) ─────────────────────────────────────────────
DATABASE_URL="mysql://root:@localhost:3306/tesis_db"
# Si XAMPP tiene contraseña: mysql://root:TU_PASSWORD@localhost:3306/tesis_db

# ─── JWT AUTH ────────────────────────────────────────────────────────────────
JWT_SECRET="9f7c2d4a8b1e6f3d0c5a7e9b2f4d8c1a6e3f7b9d2c4a8e1f5b7c9d3a6e2f8b1"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="8e3f1c7a4d9b2f6e0a5c8d1f7b3e9a2c6d4f1b8e5a7c0d9f2b6e3a1c8d5f7b4e9a2c1d6f8b3"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ─── MINIO (Almacenamiento de Archivos) ──────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="santos_admin"
MINIO_SECRET_KEY="santos_minio_2024"
MINIO_BUCKET="santos-documents"
MINIO_TEMPLATES_BUCKET="santos-templates"
MINIO_REPORTS_BUCKET="santos-reports"

# ─── INTELIGENCIA ARTIFICIAL ─────────────────────────────────────────────────
# Proveedor: 'openai' o 'ollama'
AI_PROVIDER="openai"
AI_MODEL="gpt-4o-mini"
# Para producción usar: gpt-4o

# OpenAI
OPENAI_API_KEY="your_api_key_here"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
# Para más precisión: text-embedding-3-large

# Ollama (alternativa local - sin costo)
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# ─── EMAIL (Configurado para UNT - Gmail) ──────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="YOUR_EMAIL_HERE"
SMTP_PASS="YOUR_PASS_HERE"
EMAIL_FROM="YOUR_EMAIL_HERE"
EMAIL_FROM_NAME="Sistema de Tesis - UNT"

# Para producción (Gmail):
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="tu-email@gmail.com"
# SMTP_PASS="tu-app-password"

# ─── APLICACIÓN ──────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT=3001
APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"
MAX_FILE_SIZE_MB=50

# ─── INSTITUCIÓN ─────────────────────────────────────────────────────────────
INSTITUTION_NAME="Universidad Nacional DE TRUJILLO"
INSTITUTION_SHORT="UNT"
INSTITUTION_LOGO_URL="/logo.png"

# ─── SEGURIDAD ────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=10
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ─── PUPPETEER (Generación de PDFs) ──────────────────────────────────────────
PUPPETEER_EXECUTABLE_PATH=""  # Dejar vacío para usar el Chrome bundled
