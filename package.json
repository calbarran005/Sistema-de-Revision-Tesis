{
  "name": "santos-sistema-s6",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de Gestión y Evaluación de Avances de Tesis Universitarias",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "build": "npm run build --workspace=packages/database && npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "db:generate": "npm run db:generate --workspace=packages/database",
    "db:migrate": "npm run db:migrate --workspace=packages/database",
    "db:push": "npm run db:push --workspace=packages/database",
    "db:studio": "npm run db:studio --workspace=packages/database",
    "db:seed": "npm run db:seed --workspace=packages/database",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "npx ts-node packages/database/prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
